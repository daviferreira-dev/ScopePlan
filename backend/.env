# ScopePlan Backend Configuration
# Copy this file to .env and configure your values

# Flask Configuration
FLASK_ENV=development
FLASK_APP=run.py
PORT=5000

# Security Keys (change these in production!)
SECRET_KEY=scopeplan-dev-secret-2024
JWT_SECRET_KEY=scopeplan-jwt-secret-2024

# Database (optional, defaults to SQLite)
# DATABASE_URL=sqlite:///scopepan.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/scopepan

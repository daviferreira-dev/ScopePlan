# ScopePlan Backend Configuration
# Copy this file to .env and configure your values

# Flask Configuration
FLASK_ENV=development
FLASK_APP=run.py
PORT=5000

# Security Keys — REQUIRED in production, STRONGLY recommended in dev
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-GENERATE-A-SECURE-RANDOM-KEY
JWT_SECRET_KEY=CHANGE-ME-GENERATE-A-SECURE-RANDOM-KEY

# Database — defaults to SQLite if not set
# DATABASE_URL=sqlite:///scopeplan.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/scopeplan

# CORS — comma-separated allowed origins
# Dev default: http://localhost:5173,http://localhost:3000
# Production: MUST be set (e.g. https://scopeplan.example.com)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting Storage
# Dev default: memory:// (per-process, no Redis needed)
# Production: use Redis for multi-worker rate limiting
RATE_LIMIT_STORAGE_URI=memory://
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379/0

# Rate Limit Thresholds
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_REGISTER=3/minute

# PII Encryption (LGPD) — required in production, optional in dev
# Generate FERNET_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate HMAC_KEY  : python -c "import secrets; print(secrets.token_hex(32))"
FERNET_KEY=
HMAC_KEY=

# Frontend URL — used in invite emails
FRONTEND_URL=http://localhost:5173
# Production: FRONTEND_URL=https://your-app.onrender.com

# Email Backend — 'console' logs to terminal (dev), 'smtp' sends real email (prod)
MAIL_BACKEND=console
# SMTP settings (required when MAIL_BACKEND=smtp)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# MAIL_FROM=no-reply@scopeplan.app
